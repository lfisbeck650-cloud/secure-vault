{
  "id": "com.securevault.desktop",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "secure-vault",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=session-bus",
    "--share=ipc",
    "--device=dri",
    "--filesystem=home",
    "--talk-name=org.freedesktop.portal.*",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=com.canonical.indicator.appmenu",
    "--env=GTK_THEME=Adwaita"
  ],
  "modules": [
    {
      "name": "secure-vault",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 app /app/bin/secure-vault",
        "install -Dm644 com.securevault.desktop.desktop /app/share/applications/com.securevault.desktop.desktop",
        "install -Dm644 icon_32.png /app/share/icons/hicolor/32x32/apps/com.securevault.desktop.png",
        "install -Dm644 icon_128.png /app/share/icons/hicolor/128x128/apps/com.securevault.desktop.png",
        "install -Dm644 icon_256.png /app/share/icons/hicolor/256x256/apps/com.securevault.desktop.png"
      ],
      "sources": [
        {
          "type": "file",
          "path": "../target/release/app"
        },
        {
          "type": "file",
          "path": "../flatpak/com.securevault.desktop.desktop"
        },
        {
          "type": "file",
          "path": "../apps/desktop/src-tauri/icons/32x32.png",
          "dest-filename": "icon_32.png"
        },
        {
          "type": "file",
          "path": "../apps/desktop/src-tauri/icons/128x128.png",
          "dest-filename": "icon_128.png"
        },
        {
          "type": "file",
          "path": "../apps/desktop/src-tauri/icons/128x128@2x.png",
          "dest-filename": "icon_256.png"
        }
      ]
    }
  ]
}
